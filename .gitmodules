# Git Submodules for Serving Agent
#
# 必需依赖（✅ 必须）
# 可选依赖（⚠️ 可选）
# 参考实现（📚 参考）

[submodule "modules/pypto"]
	path = modules/pypto
	url = https://github.com/hw-native-sys/pypto
	branch = main
	description = "PyPTO 主框架 - AI 加速器编程框架（必须）"

[submodule "modules/simpler"]
	path = modules/simpler
	url = https://github.com/hw-native-sys/simpler
	branch = main
	description = "Simpler Runtime - PTO 任务运行时（必须）"

[submodule "modules/pypto_runtime_distributed"]
	path = modules/pypto_runtime_distributed
	url = https://github.com/hengliao1972/pypto_runtime_distributed
	branch = main
	description = "Linqu Distributed Runtime - 分布式运行时（必须，Phase 4）"

[submodule "modules/pypto-lib"]
	path = modules/pypto-lib
	url = https://github.com/hw-native-sys/pypto-lib
	branch = main
	description = "PyPTO 库 - Tensor 操作和模型实现（可选）"

[submodule "modules/pypto-serving"]
	path = modules/pypto-serving
	url = https://github.com/hengliao1972/pypto-serving
	branch = main
	description = "PyPTO Serving - 推理引擎参考架构（可选）"

[submodule "modules/pto-isa"]
	path = modules/pto-isa
	url = https://github.com/PTO-ISA/pto-isa
	branch = main
	description = "PTO ISA - 虚拟指令集实现（间接依赖）"

[submodule "modules/PTOAS"]
	path = modules/PTOAS
	url = https://github.com/zhangstevenunity/PTOAS
	branch = main
	description = "PTOAS - PTO 编译器（间接依赖）"

[submodule "reference/rust_llm_server"]
	path = reference/rust_llm_server
	url = https://github.com/xwhu/pypto_workspace
	branch = main
	description = "参考实现 - Rust LLM 服务器"
